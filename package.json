{
  "name": "ultimate-ppt-master",
  "private": true,
  "version": "6.0.0",
  "description": "AI PPT delivery system that clarifies the brief first, then turns local source material into editable PPTX/Web Decks with visual review and audit trails.",
  "scripts": {
    "setup": "bash scripts/bootstrap.sh",
    "update": "git pull --ff-only && npm run setup",
    "desktop": "bash scripts/run-desktop.sh",
    "doctor": "bash scripts/doctor.sh",
    "bridge": "node apps/bridge/server.mjs",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "preview:web": "npm --prefix apps/web run preview",
    "build:desktop": "npm --prefix apps/desktop run build",
    "app:desktop": "npm --prefix apps/desktop run tauri:dev",
    "package:desktop": "npm --prefix apps/desktop run tauri:build",
    "package:desktop:dmg": "npm --prefix apps/desktop run tauri:build:dmg",
    "package:desktop:homebrew": "bash scripts/package-homebrew-release.sh",
    "audit:docs": "python3 scripts/audit_docs_links.py",
    "audit:web-console": "python3 scripts/audit_web_console.py",
    "audit:v6-workspace": "python3 scripts/audit_v6_workspace.py",
    "audit:brief": "python3 scripts/audit_brief_contract.py",
    "audit:visual-intent": "python3 scripts/audit_visual_intent.py",
    "audit:feedback-loop": "python3 scripts/audit_feedback_loop.py",
    "audit:repo-hygiene": "python3 scripts/audit_repository_hygiene.py",
    "audit:image-contracts": "python3 scripts/audit_image_contracts.py",
    "audit:magazine-deck": "node scripts/validate-magazine-deck.mjs examples/magazine-v54-demo/index.html",
    "audit:swiss-deck": "node scripts/validate-swiss-deck.mjs examples/swiss-v54-demo/index.html",
    "audit:featured-decks": "node scripts/validate-featured-decks.mjs",
    "audit:presets": "python3 scripts/audit_preset_packs.py",
    "audit:quality": "python3 scripts/audit_quality_proofs.py",
    "audit:market": "python3 scripts/audit_skill_market.py",
    "test:worker": "bash -lc 'if [ -x .venv/bin/python ]; then .venv/bin/python -m unittest discover -s tests; else python3 -m unittest discover -s tests; fi'",
    "test:node": "node --test tests/*.test.mjs",
    "test:bridge": "node --test tests/bridge.test.mjs"
  }
}
