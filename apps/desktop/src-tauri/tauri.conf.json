{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "终极融合 PPT 大师",
  "version": "6.3.7",
  "identifier": "com.kdnsna.ultimate-ppt-master",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "终极融合 PPT 大师",
        "width": 1280,
        "height": 820,
        "minWidth": 1040,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/desktop_worker.py",
      "resources/requirements.txt"
    ]
  }
}
